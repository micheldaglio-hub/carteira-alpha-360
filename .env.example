APP_NAME=Carteira Alpha 360
ENVIRONMENT=development
SECRET_KEY=troque-esta-chave-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=720

# PostgreSQL recomendado para producao/local com Docker.
DATABASE_URL=postgresql+psycopg://carteira_alpha:carteira_alpha@localhost:5432/carteira_alpha
DATABASE_AUTO_CREATE_TABLES=true

# Para preview sem PostgreSQL, o backend aceita SQLite:
# DATABASE_URL=sqlite:///./carteira_alpha.db

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|[A-Za-z0-9-]+(?:\.local)?|192\.168\.\d+\.\d+|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+)(:\d+)?$
SEED_DEMO_DATA=true

# Providers externos preparados para evolucao.
MARKET_DATA_PROVIDER=brapi
BRAPI_TOKEN=
COINMARKETCAP_API_KEY=
COINGECKO_API_KEY=
FMP_API_KEY=
TWELVE_DATA_API_KEY=
DADOS_MERCADO_API_TOKEN=
FINTZ_API_KEY=
CVM_BASE_URL=https://dados.cvm.gov.br
B3_BASE_URL=https://sistemaswebb3-listados.b3.com.br
DADOS_MERCADO_BASE_URL=https://api.dadosdemercado.com.br/v1
FMP_BASE_URL=https://financialmodelingprep.com/stable
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
BCB_SGS_BASE_URL=https://api.bcb.gov.br/dados/serie
FINTZ_BASE_URL=https://api.fintz.com.br

# Alpha Copilot com IA.
# Mantido desligado por padrao. O frontend nunca chama IA diretamente.
ALPHA_COPILOT_AI_ENABLED=false
ALPHA_COPILOT_PROVIDER=openai
ALPHA_COPILOT_MODEL=gpt-4o-mini
ALPHA_COPILOT_TIMEOUT_SECONDS=20
ALPHA_COPILOT_MAX_CONTEXT_CHARS=18000
ALPHA_COPILOT_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Observabilidade, auditoria e jobs.
OBSERVABILITY_JSON_LOGS=true
OBSERVABILITY_LOG_REQUEST_BODY=false
AUDIT_ENABLED=true
AUDIT_HTTP_MUTATIONS=true
AUDIT_RETENTION_DAYS=365
JOBS_ENABLED=false
JOBS_HEARTBEAT_INTERVAL_SECONDS=300
JOBS_CLEANUP_INTERVAL_SECONDS=3600
JOBS_GUARDIAN_INTERVAL_SECONDS=21600
JOBS_MARKET_DATA_INTERVAL_SECONDS=3600
JOBS_MODEL_PORTFOLIOS_INTERVAL_SECONDS=21600
JOBS_MACRO_FX_INTERVAL_SECONDS=3600
JOBS_FORMULA_AUDIT_INTERVAL_SECONDS=86400
BACKUP_DIRECTORY=backups
MONITORING_WEBHOOK_URL=

# Gateway de pagamento.
# Em desenvolvimento use mock; em producao configure Stripe/Mercado Pago apenas no backend.
BILLING_PAYMENT_PROVIDER=mock
BILLING_CHECKOUT_EXPIRES_MINUTES=60
BILLING_WEBHOOK_SECRET=
BILLING_PUBLIC_BASE_URL=http://127.0.0.1:5173
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# Distribution Engine.
# Mock registra entrega sem enviar email real.
DISTRIBUTION_PROVIDER=mock
DISTRIBUTION_FROM_EMAIL=research@carteiraalpha.local
DISTRIBUTION_REPLY_TO=
DISTRIBUTION_WEBHOOK_SECRET=
DISTRIBUTION_PUBLIC_BASE_URL=http://127.0.0.1:5173
DISTRIBUTION_RESEND_API_KEY=
DISTRIBUTION_RESEND_BASE_URL=https://api.resend.com
DISTRIBUTION_SMTP_HOST=
DISTRIBUTION_SMTP_PORT=587
DISTRIBUTION_SMTP_USERNAME=
DISTRIBUTION_SMTP_PASSWORD=
DISTRIBUTION_SMTP_USE_TLS=true

# Provider secundario e opcional para validacao/comparacao fundamentalista.
# Mantido desativado por padrao para respeitar disponibilidade, termos e robots do site.
FUNDAMENTUS_ENABLED=false
FUNDAMENTUS_BASE_URL=https://www.fundamentus.com.br
FUNDAMENTUS_RATE_LIMIT_SECONDS=45
FUNDAMENTUS_TIMEOUT_SECONDS=6

# Integracao opcional, somente leitura, com Trading Desk EV+.
TRADING_DESK_ENABLED=false
TRADING_DESK_API_URL=http://127.0.0.1:8510
TRADING_DESK_INTEGRATION_KEY=
TRADING_DESK_TIMEOUT_SECONDS=4
TRADING_DESK_LOCAL_PATH=C:\Users\miche\OneDrive\Documentos\Trading Desk EV+
