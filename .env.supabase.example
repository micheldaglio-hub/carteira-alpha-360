APP_NAME=Carteira Alpha 360
ENVIRONMENT=production
SECRET_KEY=troque-por-uma-chave-longa-com-64-ou-mais-caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Cole a senha real no lugar de SUA_SENHA. Nao commitar .env real.
# Recomendado para Render/Supabase quando Direct Connection nao estiver disponivel via IPv4:
DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:SUA_SENHA_URL_ENCODED@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# Alternativa Direct Connection, se a rede tiver IPv6 funcional:
# DATABASE_URL=postgresql+psycopg://postgres:SUA_SENHA_URL_ENCODED@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_AUTO_CREATE_TABLES=false
SEED_DEMO_DATA=false

BACKEND_CORS_ORIGINS=https://app.seudominio.com
BACKEND_CORS_ORIGIN_REGEX=

MARKET_DATA_PROVIDER=brapi
BRAPI_TOKEN=
COINMARKETCAP_API_KEY=
COINGECKO_API_KEY=
FMP_API_KEY=
TWELVE_DATA_API_KEY=
DADOS_MERCADO_API_TOKEN=
FINTZ_API_KEY=

OBSERVABILITY_JSON_LOGS=true
OBSERVABILITY_LOG_REQUEST_BODY=false
AUDIT_ENABLED=true
AUDIT_HTTP_MUTATIONS=true
AUDIT_RETENTION_DAYS=365
JOBS_ENABLED=true
JOBS_HEARTBEAT_INTERVAL_SECONDS=300
JOBS_CLEANUP_INTERVAL_SECONDS=3600
JOBS_GUARDIAN_INTERVAL_SECONDS=21600
JOBS_MARKET_DATA_INTERVAL_SECONDS=3600
JOBS_MODEL_PORTFOLIOS_INTERVAL_SECONDS=21600
JOBS_MACRO_FX_INTERVAL_SECONDS=3600
JOBS_FORMULA_AUDIT_INTERVAL_SECONDS=86400
BACKUP_DIRECTORY=backups
MONITORING_WEBHOOK_URL=

BILLING_PAYMENT_PROVIDER=mock
BILLING_CHECKOUT_EXPIRES_MINUTES=60
BILLING_WEBHOOK_SECRET=
BILLING_PUBLIC_BASE_URL=https://app.seudominio.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

DISTRIBUTION_PROVIDER=mock
DISTRIBUTION_FROM_EMAIL=research@seudominio.com
DISTRIBUTION_REPLY_TO=
DISTRIBUTION_WEBHOOK_SECRET=
DISTRIBUTION_PUBLIC_BASE_URL=https://app.seudominio.com
DISTRIBUTION_RESEND_API_KEY=
DISTRIBUTION_RESEND_BASE_URL=https://api.resend.com
DISTRIBUTION_SMTP_HOST=
DISTRIBUTION_SMTP_PORT=587
DISTRIBUTION_SMTP_USERNAME=
DISTRIBUTION_SMTP_PASSWORD=
DISTRIBUTION_SMTP_USE_TLS=true

ALPHA_COPILOT_AI_ENABLED=false
ALPHA_COPILOT_PROVIDER=openai
ALPHA_COPILOT_MODEL=gpt-4o-mini
ALPHA_COPILOT_API_KEY=
OPENAI_API_KEY=

TRADING_DESK_ENABLED=false
TRADING_DESK_API_URL=
TRADING_DESK_INTEGRATION_KEY=
TRADING_DESK_TIMEOUT_SECONDS=4
TRADING_DESK_LOCAL_PATH=
